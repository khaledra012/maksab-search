# Core app
NODE_ENV=development
PORT=3000
DATABASE_URL=mysql://USER:PASSWORD@HOST:3306/DB_NAME
JWT_SECRET=change-this-secret

OWNER_OPEN_ID=
VITE_APP_URL=http://localhost:3000

# Direct Google Maps
GOOGLE_MAPS_API_KEY=
VITE_GOOGLE_MAPS_API_KEY=

# First-party storage (S3/R2/MinIO compatible)
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_REGION=
S3_ENDPOINT=
PUBLIC_STORAGE_BASE_URL=

# Supabase Storage
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=uploads

# Legacy Forge / storage / built-in services
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=
VITE_FRONTEND_FORGE_API_KEY=

# Direct Gemini LLM (used by server-side analysis)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Bright Data - browser + SERP + residential proxy
BRIGHT_DATA_WS_ENDPOINT=
BRIGHT_DATA_API_TOKEN=
BRIGHT_DATA_SERP_ZONE=serp_api1
BRIGHT_DATA_SERP_HOST=brd.superproxy.io
BRIGHT_DATA_SERP_PORT=33335
BRIGHT_DATA_SERP_USERNAME=
BRIGHT_DATA_SERP_PASSWORD=
BRIGHT_DATA_RESIDENTIAL_HOST=brd.superproxy.io
BRIGHT_DATA_RESIDENTIAL_PORT=33335
BRIGHT_DATA_RESIDENTIAL_USERNAME=
BRIGHT_DATA_RESIDENTIAL_PASSWORD=

# Google
GOOGLE_PAGESPEED_API_KEY=
GOOGLE_CUSTOM_SEARCH_API_KEY=
GOOGLE_CUSTOM_SEARCH_ENGINE_ID=

# Instagram Graph API fallback
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_APP_ID=

# Email / SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=Maksab Sales

# Browser override for local Windows/Linux/Mac runs if auto-detect fails
PUPPETEER_EXECUTABLE_PATH=
CHROME_BIN=

# Whatchimp fallback (used when no active settings row exists in DB)
WHATCHIMP_API_TOKEN=
WHATCHIMP_PHONE_NUMBER_ID=
WHATCHIMP_BOT_FLOW_UNIQUE_ID=

# Configured inside app/database or optionally here:
# - OpenAI / Claude / Groq keys: AI Settings page
# - Gemini server-side analysis now uses GEMINI_API_KEY / GEMINI_MODEL from env
# - Instagram App Secret: AI Settings page
# - Whatchimp botFlowUniqueId can still be set from Settings > Whatchimp
